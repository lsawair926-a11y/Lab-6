#include "mbed.h"
#include "arm_book_lib.h"

#include "user_interface.h"

#include "code.h"
#include "siren.h"
#include "smart_home_system.h"
#include "fire_alarm.h"
#include "date_and_time.h"
#include "temperature_sensor.h"
#include "gas_sensor.h"
#include "matrix_keypad.h"
#include "display.h"



#define DISPLAY_REFRESH_TIME_MS 1000
#define TEMP_WARNING_THRESHOLD 30



DigitalOut incorrectCodeLed(LED3);
DigitalOut systemBlockedLed(LED2);



char codeSequenceFromUserInterface[CODE_NUMBER_OF_KEYS];
char correctCode[CODE_NUMBER_OF_KEYS] = {'1','2','1','1','1'};



static bool incorrectCodeState = OFF;
static bool systemBlockedState = OFF;

static bool showGasReport = false;
static bool showTempReport = false;

static bool codeComplete = false;
static int numberOfCodeChars = 0;



static void userInterfaceMatrixKeypadUpdate();
static void incorrectCodeIndicatorUpdate();
static void systemBlockedIndicatorUpdate();
static void userInterfaceDisplayInit();
static void userInterfaceDisplayUpdate();



void userInterfaceInit()
{
    incorrectCodeLed = OFF;
    systemBlockedLed = OFF;
    matrixKeypadInit( SYSTEM_TIME_INCREMENT_MS );
    userInterfaceDisplayInit();
}

void userInterfaceUpdate()
{
    userInterfaceMatrixKeypadUpdate();
    incorrectCodeIndicatorUpdate();
    systemBlockedIndicatorUpdate();
    userInterfaceDisplayUpdate();
}

bool incorrectCodeStateRead()
{
    return incorrectCodeState;
}

void incorrectCodeStateWrite( bool state )
{
    incorrectCodeState = state;
}

bool systemBlockedStateRead()
{
    return systemBlockedState;
}

void systemBlockedStateWrite( bool state )
{
    systemBlockedState = state;
}

bool userInterfaceCodeCompleteRead()
{
    return codeComplete;
}

void userInterfaceCodeCompleteWrite( bool state )
{
    codeComplete = state;
}

bool isCodeCorrect() {
    for (int i = 0; i < CODE_NUMBER_OF_KEYS; i++) {
        if (codeSequenceFromUserInterface[i] != correctCode[i]) {
            return false;
        }
    }
    return true;
}


static void userInterfaceMatrixKeypadUpdate()
{
    static int numberOfHashKeyReleased = 0;

    char keyReleased = matrixKeypadUpdate();

  
    if (keyReleased == '4') {
        showGasReport = true;
        showTempReport = false;
    }

    if (keyReleased == '5') {
        showTempReport = true;
        showGasReport = false;
    }

    if( keyReleased != '\0' ) {

        if( sirenStateRead() && !systemBlockedStateRead() ) {
            if( !incorrectCodeStateRead() ) {
                codeSequenceFromUserInterface[numberOfCodeChars] = keyReleased;
                numberOfCodeChars++;
           if ( numberOfCodeChars >= CODE_NUMBER_OF_KEYS ) {

    if (isCodeCorrect()) {
        sirenStateWrite(OFF);   // deactivate alarm
    } else {
        incorrectCodeState = ON;
    }

    codeComplete = true;
    numberOfCodeChars = 0;
    
}
                }
            } else {
                if( keyReleased == '#' ) {
                    numberOfHashKeyReleased++;
                    if( numberOfHashKeyReleased >= 2 ) {
                        numberOfHashKeyReleased = 0;
                        numberOfCodeChars = 0;
                        codeComplete = false;
                        incorrectCodeState = OFF;
                    }
                }
            }
        }
    }



static void userInterfaceDisplayInit()
{
    displayInit( DISPLAY_CONNECTION_I2C_PCF8574_IO_EXPANDER );
     
    displayCharPositionWrite ( 0,0 );
    displayStringWrite( "Temperature:" );

    displayCharPositionWrite ( 0,1 );
    displayStringWrite( "Gas:" );
    
    displayCharPositionWrite ( 0,2 );
    displayStringWrite( "Alarm:" );
}


static void userInterfaceDisplayUpdate()
{
    static int accumulatedDisplayTime = 0;
    static int oneMinuteCounter = 0;


    if (sirenStateRead()) {

        displayCharPositionWrite(0,0);
        displayStringWrite("Enter Code:     ");

        displayCharPositionWrite(0,1);

        for (int i = 0; i < numberOfCodeChars; i++) {
            displayStringWrite("*");
        }

        displayCharPositionWrite(0,2);
        displayStringWrite("                ");

        return;
    }


    if (temperatureSensorReadCelsius() > TEMP_WARNING_THRESHOLD || gasDetectorStateRead()) {

        displayCharPositionWrite(0,0);
        displayStringWrite("!!! WARNING !!! ");

        displayCharPositionWrite(0,1);

        if (gasDetectorStateRead()) {
            displayStringWrite("GAS DETECTED!   ");
        }
        else if (temperatureSensorReadCelsius() > TEMP_WARNING_THRESHOLD) {
            displayStringWrite("TEMP TOO HIGH!  ");
        }

        displayCharPositionWrite(0,2);
        displayStringWrite("                ");

        return;
    }

    
    if (showGasReport || showTempReport) {

        displayCharPositionWrite(0,0);
        displayStringWrite("                ");
        displayCharPositionWrite(0,1);
        displayStringWrite("                ");
        displayCharPositionWrite(0,2);
        displayStringWrite("                ");

        if (showGasReport) {
            displayCharPositionWrite(0,0);
            displayStringWrite("Gas Status:");

            displayCharPositionWrite(0,1);
            if (gasDetectorStateRead()) displayStringWrite("DETECTED!");
            else displayStringWrite("SAFE");

            return;
        }

        if (showTempReport) {
            displayCharPositionWrite(0,0);
            displayStringWrite("Temp Status:");

            displayCharPositionWrite(0,1);
            if (temperatureSensorReadCelsius() > 30) displayStringWrite("HIGH!");
            else displayStringWrite("NORMAL");

            return;
        }
    }

    if (oneMinuteCounter >= 5000) {

        oneMinuteCounter = 0;

        displayCharPositionWrite(0,0);
        displayStringWrite("Alarm Status:   ");

        displayCharPositionWrite(0,1);
        if (sirenStateRead()) displayStringWrite("ON ");
        else displayStringWrite("OFF");

        displayCharPositionWrite(0,2);
        displayStringWrite("                ");

        return;
    }

    if (accumulatedDisplayTime >= DISPLAY_REFRESH_TIME_MS) {

        accumulatedDisplayTime = 0;

        char temperatureString[8];
        sprintf(temperatureString, "%.0f", temperatureSensorReadCelsius());

        displayCharPositionWrite(0,0);
        displayStringWrite("Temperature:");
        displayCharPositionWrite(12,0);
        displayStringWrite(temperatureString);
        displayStringWrite("'C ");

        displayCharPositionWrite(0,1);
        displayStringWrite("Gas:");
        displayCharPositionWrite(4,1);

        if (gasDetectorStateRead()) displayStringWrite("Detected    ");
        else displayStringWrite("Not Detected");

        displayCharPositionWrite(0,2);
        displayStringWrite("Alarm:");
        displayCharPositionWrite(6,2);

        if (sirenStateRead()) displayStringWrite("ON ");
        else displayStringWrite("OFF");
    }
    else {
        accumulatedDisplayTime += SYSTEM_TIME_INCREMENT_MS;
    }

    oneMinuteCounter += SYSTEM_TIME_INCREMENT_MS;
}


static void incorrectCodeIndicatorUpdate()
{
    incorrectCodeLed = incorrectCodeStateRead();
}

static void systemBlockedIndicatorUpdate()
{
    systemBlockedLed = systemBlockedState;
}
